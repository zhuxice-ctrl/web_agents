{
  "name": "tablellm",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "products/roundtable"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start:roundtable": "npm --workspace @web-agents/roundtable-product start",
    "check:boundaries": "node tools/check-product-boundaries.mjs",
    "test:boundaries": "node --test tools/check-product-boundaries.test.mjs",
    "test:roundtable": "npm --workspace @web-agents/roundtable-product test",
    "test:compat": "npm --workspace @web-agents/roundtable-product run test:compat",
    "test": "npm run check:boundaries && npm run test:boundaries && npm run test:roundtable && npm run test:compat"
  }
}
