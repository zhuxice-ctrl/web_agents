{
  "name": "web-ai-local-mcp-bridge",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "products/*",
    "products/*/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "check:boundaries": "node tools/check-product-boundaries.mjs",
    "test:core": "npm --workspace @web-agents/local-core test",
    "test:council-browser": "node --test products/roundtable/tests/legacy-council/council-browser.test.mjs",
    "test:config-gateway": "node --test products/plugin/services/config-gateway.test.mjs",
    "test:roundtable-compat-extension": "node --test products/roundtable/compat-extension/test/*.test.mjs",
    "test:plugin": "npm --workspace @web-agents/plugin-product test",
    "test:launcher": "npm --workspace @web-agents/roundtable-product run test:launcher",
    "test:roundtable-web": "npm --workspace @web-agents/roundtable-product run test:core",
    "test:roundtable-browser": "npm --workspace @web-agents/roundtable-product run test:browser",
    "test:roundtable": "npm --workspace @web-agents/roundtable-product test",
    "start:roundtable": "npm --workspace @web-agents/roundtable-product start",
    "test:all": "npm run check:boundaries && npm run test:core && npm run test:plugin && npm run test:roundtable",
    "test:local-runtime": "npm run test:config-gateway && npm run test:plugin && npm run test:roundtable-compat-extension && npm run test:roundtable-web && npm run test:council-browser && npm run test:roundtable-browser && npm run test:launcher"
  },
  "dependencies": {
    "@playwright/mcp": "0.0.78",
    "playwright": "^1.61.1"
  }
}
